# Keep this key only in your local process environment or an ignored local file.
# Lumi's Electron main process uses it to mint Realtime credentials and make
# explicitly confirmed GPT-5.6 screen-review requests. Never expose it to renderer code.
OPENAI_API_KEY=your_openai_api_key

# Realtime voice and image-context model. The mini model is Lumi's safe default;
# set gpt-realtime-2.1 for the higher-quality Realtime model when needed.
LIFELENS_REALTIME_MODEL=gpt-realtime-2.1-mini
# Valid values for supported Realtime models: low, medium, high.
LIFELENS_REALTIME_REASONING=low

# Read-only structured reasoning over one explicitly confirmed screen capture.
# Verified during Build Week against the Responses API on 2026-07-20.
LUMI_REASONING_MODEL=gpt-5.6-terra
# Valid values: low, medium, high. Low keeps the review responsive.
LUMI_REASONING_EFFORT=low

# Optional Telegram integration. Leave blank unless you configure it locally.
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
